{
  "name": "@taimoorchatha/tada",
  "version": "0.1.3",
  "description": "A CLI todo app.",
  "type": "module",
  "bin": {
    "tada": "./dist/cli/index.js"
  },
  "exports": {
    ".": "./dist/core/index.js",
    "./mcp": "./dist/mcp/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli/index.ts",
    "dev:mcp": "tsx src/mcp/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "date-fns": "^4.0.0",
    "ink": "^6.8.0",
    "ink-text-input": "^6.0.0",
    "nanoid": "^5.0.0",
    "react": "^19.2.4",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
