{
  "name": "@taimoorchatha/tada",
  "version": "0.1.5",
  "description": "Things-inspired CLI todo manager with TUI and MCP server for AI coding assistants like Claude Code.",
  "keywords": [
    "todo",
    "todos",
    "cli",
    "tui",
    "mcp",
    "claude",
    "claude-code",
    "ai",
    "ai-assistant",
    "task-manager",
    "tasks",
    "terminal",
    "things",
    "productivity",
    "gtd",
    "ink",
    "react",
    "typescript"
  ],
  "author": "Taimoor Chatha",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/taimoorchatha/tada.git"
  },
  "homepage": "https://github.com/taimoorchatha/tada#readme",
  "bugs": {
    "url": "https://github.com/taimoorchatha/tada/issues"
  },
  "bin": {
    "tada": "./dist/cli/index.js"
  },
  "exports": {
    ".": "./dist/core/index.js",
    "./mcp": "./dist/mcp/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli/index.ts",
    "dev:mcp": "tsx src/mcp/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "date-fns": "^4.0.0",
    "ink": "^6.8.0",
    "ink-text-input": "^6.0.0",
    "nanoid": "^5.0.0",
    "react": "^19.2.4",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
